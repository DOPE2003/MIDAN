# Copy this file to .env.local and fill in your SMTP credentials.
# The contact form will send emails to CONTACT_TO via your SMTP server.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Destination email (defaults to projects@midangrup.com if not set)
CONTACT_TO=projects@midangrup.com
